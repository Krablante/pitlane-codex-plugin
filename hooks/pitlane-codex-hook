#!/usr/bin/env python3

from __future__ import annotations

import json
import hashlib
import os
import re
import shlex
import shutil
import subprocess
import sys
import datetime as _dt
from pathlib import Path


BYPASS_ENV = {
    "PITLANE_CODEX_HOOK_DISABLE",
    "PITLANE_CODEX_BYPASS",
    "PITLANE_DISABLE",
    "PITLANE_DISABLED",
}

SOURCE_EXTS = {
    ".bash",
    ".c",
    ".cc",
    ".cjs",
    ".clj",
    ".cpp",
    ".cs",
    ".css",
    ".erl",
    ".ex",
    ".exs",
    ".fish",
    ".go",
    ".h",
    ".hpp",
    ".hrl",
    ".html",
    ".java",
    ".js",
    ".jsx",
    ".kt",
    ".kts",
    ".lua",
    ".md",
    ".mdx",
    ".mjs",
    ".php",
    ".pl",
    ".pm",
    ".py",
    ".rb",
    ".rs",
    ".scala",
    ".scss",
    ".sh",
    ".sql",
    ".svelte",
    ".swift",
    ".toml",
    ".ts",
    ".tsx",
    ".vue",
    ".yaml",
    ".yml",
    ".zsh",
}

SHELL_CONTROL_RE = re.compile(r"[\n|;&<>`$()]")
SED_RANGE_RE = re.compile(r"^([0-9]+)(?:,([0-9]+))?p$")
SYMBOL_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*$")
STRONG_SYMBOL_RE = re.compile(r"^(?:[A-Za-z_][A-Za-z0-9_]*::)*[A-Z][A-Za-z0-9_]*[a-z][A-Za-z0-9_]*$")
ASSIGNMENT_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*=.*$")
SOURCE_SHEBANG_RE = re.compile(
    rb"^#!.*\b(bash|deno|fish|node|perl|php|python|python3|ruby|sh|zsh)\b"
)
SHELL_RUNNERS = {"bash", "dash", "sh", "zsh"}
SHELL_TOOL_NAMES = {"Bash", "exec_command", "functions.exec_command"}
EXCLUDED_NAV_PATH_PARTS = {
    ".cache",
    ".git",
    "__pycache__",
    "archive",
    "politia" + "-state",
    "backups",
    "build",
    "data",
    "dist",
    "generated",
    "log",
    "logs",
    "node_modules",
    "runtime-state",
    "state",
    "target",
    "tmp",
}
ABSOLUTE_EXCLUDED_NAV_PATH_PARTS = {
    "politia" + "-state",
    "data",
    "generated",
    "log",
    "logs",
    "runtime-state",
    "state",
}
EXCLUDED_NAV_SUFFIXES = {".json", ".jsonl", ".log", ".ndjson"}


def main() -> int:
    if any(enabled(os.environ.get(name)) for name in BYPASS_ENV):
        return 0

    try:
        payload = json.load(sys.stdin)
    except Exception:
        return 0

    if payload.get("hook_event_name") != "PreToolUse" or not is_shell_tool(payload):
        return 0

    original_command, command_field = command_from_payload(payload)
    command = original_command
    if not isinstance(command, str) or not command.strip():
        return 0
    command = safe_unwrap_shell_command(command)
    cwd = cwd_from_payload(payload)
    if not cwd.is_absolute():
        cwd = Path(os.getcwd())
    try:
        cwd = cwd.resolve()
    except OSError:
        cwd = Path(os.getcwd()).resolve()

    pitlane_base = resolve_pitlane_base()
    if not pitlane_base:
        try:
            tokens_for_class = shlex.split(command)
        except ValueError:
            tokens_for_class = []
        record_decision(payload, command, "unavailable", classify_tokens(tokens_for_class, cwd), "pitlane-cli-unavailable", cwd)
        return 0

    if SHELL_CONTROL_RE.search(command):
        plan = build_shell_control_plan(pitlane_base, cwd, command, payload=payload)
        if plan is not None:
            record_decision(payload, command, "rewrite", "source-pipeline", "pitlane-plan", cwd, metrics=plan.metrics)
            output = {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "updatedInput": {command_field: shell_join(plan.command)},
                }
            }
            if plan.context:
                output["hookSpecificOutput"]["additionalContext"] = plan.context
            print(json.dumps(output, separators=(",", ":")))
            return 0
        record_decision(payload, command, "pass", "shell-control", "shell-control-quiet", cwd)
        return 0

    try:
        tokens = shlex.split(command)
    except ValueError:
        return 0
    if not tokens or command_has_bypass_prefix(tokens):
        return 0

    tokens = strip_env_prefix(tokens)
    if not tokens:
        return 0

    plan = build_plan(tokens, cwd, pitlane_base, payload=payload, original_command=command)
    if plan is None:
        if should_hint_tokens(tokens, cwd):
            record_decision(payload, command, "hint", classify_tokens(tokens, cwd), "source-navigation-shell", cwd)
            emit_missed_hint(original_command, command_field, "source navigation used shell before Pitlane")
        else:
            record_decision(payload, command, "pass", classify_tokens(tokens, cwd), "not-source-navigation", cwd)
        return 0
    record_decision(payload, command, "rewrite", classify_tokens(tokens, cwd), "pitlane-plan", cwd, metrics=plan.metrics)

    output = {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "updatedInput": {command_field: shell_join(plan.command)},
        }
    }
    if plan.context:
        output["hookSpecificOutput"]["additionalContext"] = plan.context
    print(json.dumps(output, separators=(",", ":")))
    return 0


class RewritePlan:
    def __init__(self, command: list[str], context: str | None = None, metrics: dict | None = None) -> None:
        self.command = command
        self.context = context
        self.metrics = metrics or {}


def is_shell_tool(payload: dict) -> bool:
    tool_name = payload.get("tool_name")
    if not isinstance(tool_name, str):
        return False
    return tool_name in SHELL_TOOL_NAMES or tool_name.endswith(".exec_command")


def command_from_payload(payload: dict) -> tuple[str, str]:
    tool_input = payload.get("tool_input")
    if not isinstance(tool_input, dict):
        return "", "command"
    for key in ("command", "cmd"):
        value = tool_input.get(key)
        if isinstance(value, str):
            return value, key
    return "", "command"


def safe_unwrap_shell_command(command: str) -> str:
    try:
        tokens = shlex.split(command.strip(), posix=True)
    except ValueError:
        return command
    if len(tokens) != 3:
        return command
    runner = Path(tokens[0]).name
    if runner not in SHELL_RUNNERS or tokens[1] not in {"-c", "-lc"}:
        return command
    inner = tokens[2].strip()
    return inner or command


def cwd_from_payload(payload: dict) -> Path:
    cwd_value = payload.get("cwd")
    tool_input = payload.get("tool_input")
    if isinstance(tool_input, dict):
        for key in ("workdir", "cwd"):
            value = tool_input.get(key)
            if isinstance(value, str) and value.strip():
                cwd_value = value
                break
    cwd = Path(cwd_value or os.getcwd())
    if not cwd.is_absolute():
        cwd = Path(os.getcwd())
    try:
        return cwd.resolve()
    except OSError:
        return Path(os.getcwd()).resolve()


def enabled(value: str | None) -> bool:
    return value is not None and value.strip().lower() not in {"", "0", "false", "no", "off"}


def command_has_bypass_prefix(tokens: list[str]) -> bool:
    for token in tokens[:6]:
        if token in {"--", "sudo"}:
            continue
        if token == "env":
            continue
        if token in {"-i", "-0"} or token.startswith("-u"):
            continue
        if "=" not in token:
            return False
        name, value = token.split("=", 1)
        if name in BYPASS_ENV and enabled(value):
            return True
    return False


def strip_env_prefix(tokens: list[str]) -> list[str]:
    idx = 0
    while idx < len(tokens) and ASSIGNMENT_RE.match(tokens[idx]):
        idx += 1
    if idx:
        return tokens[idx:]

    if tokens and tokens[0] == "env":
        idx = 1
        while idx < len(tokens):
            token = tokens[idx]
            if token == "--":
                idx += 1
                break
            if token == "-i":
                idx += 1
                continue
            if token == "-u":
                idx += 2
                continue
            if token.startswith("-u") and len(token) > 2:
                idx += 1
                continue
            if ASSIGNMENT_RE.match(token):
                idx += 1
                continue
            break
        return tokens[idx:]

    return tokens


def resolve_pitlane_base() -> list[str] | None:
    override = os.environ.get("PITLANE_CODEX_COMMAND")
    if override:
        try:
            parsed = shlex.split(override)
        except ValueError:
            return None
        if is_host_local_pitlane_command(parsed):
            return parsed
        return None

    if shutil.which("pitlane"):
        return ["pitlane"]

    return None


def is_host_local_pitlane_command(command: list[str]) -> bool:
    if not command:
        return False
    executable = Path(command[0])
    if executable.name != "pitlane":
        return False
    if not executable.is_absolute():
        return command[0] == "pitlane" and shutil.which("pitlane") is not None
    try:
        resolved = executable.resolve(strict=True)
    except OSError:
        return False
    return resolved.is_file() and os.access(resolved, os.X_OK)


def build_plan(
    tokens: list[str],
    cwd: Path,
    pitlane_base: list[str],
    *,
    payload: dict | None = None,
    original_command: str = "",
) -> RewritePlan | None:
    executable = Path(tokens[0]).name
    max_lines = int_env("PITLANE_CODEX_LINES_MAX", 220, 20, 1000)
    search_limit = int_env("PITLANE_CODEX_SEARCH_LIMIT", 30, 5, 100)

    if executable == "cat" and len(tokens) == 2 and not tokens[1].startswith("-"):
        return plan_file_lines(pitlane_base, cwd, tokens[1], 1, max_lines, max_lines, payload=payload, requested_end=None)

    if executable == "head":
        parsed = parse_head(tokens)
        if parsed is not None:
            count, path_arg = parsed
            return plan_file_lines(
                pitlane_base,
                cwd,
                path_arg,
                1,
                min(count, max_lines),
                max_lines,
                payload=payload,
                requested_end=count,
            )

    if executable == "sed":
        parsed = parse_sed_range(tokens)
        if parsed is not None:
            start, end, path_arg = parsed
            if end < start:
                return None
            capped_end = min(end, start + max_lines - 1)
            return plan_file_lines(
                pitlane_base,
                cwd,
                path_arg,
                start,
                capped_end,
                max_lines,
                payload=payload,
                requested_end=end,
            )

    if executable == "rg":
        parsed = parse_rg_symbol_search(tokens, cwd)
        if parsed is not None:
            query, file_filter = parsed
            project = git_root(cwd)
            if not ensure_pitlane_index_ready(pitlane_base, project, payload=payload):
                record_missed_opportunity(payload, original_command, "index-not-ready", cwd)
                return None
            command = [*pitlane_base, "search", str(project), query, "--limit", str(search_limit), "--mode", "fuzzy"]
            if file_filter:
                command.extend(["--file", file_filter])
            return RewritePlan(command, "Pitlane hook rewrote a simple symbol search to Pitlane search.")

    if executable == "grep":
        parsed = parse_grep_recursive_symbol_search(tokens, cwd)
        if parsed is not None:
            query, file_filter = parsed
            project = git_root(cwd)
            if not ensure_pitlane_index_ready(pitlane_base, project, payload=payload):
                record_missed_opportunity(payload, original_command, "index-not-ready", cwd)
                return None
            command = [*pitlane_base, "search", str(project), query, "--limit", str(search_limit), "--mode", "fuzzy"]
            if file_filter:
                command.extend(["--file", file_filter])
            return RewritePlan(command, "Pitlane hook rewrote a recursive symbol grep to Pitlane search.")

    if executable in {"ls", "tree"}:
        parsed = parse_recursive_listing(tokens, cwd)
        if parsed is not None:
            path_arg = parsed
            path = resolve_existing_path(cwd, path_arg)
            if path is None:
                record_missed_opportunity(payload, original_command, "path-not-found", cwd)
                return None
            project = git_root(path if path.is_dir() else path.parent)
            if not ensure_pitlane_index_ready(pitlane_base, project, payload=payload):
                record_missed_opportunity(payload, original_command, "index-not-ready", cwd)
                return None
            rel = relative_to_project(path, project)
            command = [*pitlane_base, "outline", str(project), "--depth", "2", "--summary"]
            if rel not in {"", "."}:
                command.extend(["--path", rel])
            return RewritePlan(command, "Pitlane hook rewrote a recursive listing to Pitlane outline.")

    if looks_like_source_navigation(tokens, cwd):
        record_missed_opportunity(payload, original_command, "unsupported-source-navigation-shape", cwd)
    return None


def plan_file_lines(
    pitlane_base: list[str],
    cwd: Path,
    path_arg: str,
    start: int,
    end: int,
    max_lines: int,
    payload: dict | None = None,
    requested_end: int | None = None,
) -> RewritePlan | None:
    if path_arg_is_excluded_from_navigation(path_arg):
        return None
    resolved = resolve_existing_path(cwd, path_arg)
    if resolved is not None and path_is_excluded_from_navigation(resolved):
        return None
    path = resolve_source_file(cwd, path_arg)
    if path is None:
        record_missed_opportunity(payload, f"source-read {path_arg}", "source-path-not-supported", cwd)
        return None

    project = git_root(path.parent)
    ensure_pitlane_index_ready(pitlane_base, project, payload=payload, required=False)
    rel = relative_to_project(path, project)
    total = count_text_lines(path, max_lines + 1)
    if total is None:
        return None

    if start == 1:
        end = min(end, total)
    if end < start:
        return None

    command = [*pitlane_base, "lines", str(project), rel, str(start), str(end)]
    metrics = estimate_line_savings(path, start, end, requested_end=requested_end, total_lines=total)
    context = (
        "Pitlane hook rewrote a broad source read to Pitlane lines. "
        "Ask for narrower line ranges or Pitlane symbol/search tools when more context is needed."
    )
    return RewritePlan(command, context, metrics)


def build_shell_control_plan(
    pitlane_base: list[str],
    cwd: Path,
    command: str,
    *,
    payload: dict | None = None,
) -> RewritePlan | None:
    segments = split_single_unquoted_pipe(command)
    if segments is None:
        return None
    left_text, right_text = segments
    try:
        left = shlex.split(left_text)
        right = shlex.split(right_text)
    except ValueError:
        return None
    max_lines = int_env("PITLANE_CODEX_LINES_MAX", 220, 20, 1000)
    if len(left) == 2 and Path(left[0]).name == "cat":
        parsed_head = parse_head(right)
        if parsed_head is not None and parsed_head[1] == "-":
            count, _stdin = parsed_head
            return plan_file_lines(
                pitlane_base,
                cwd,
                left[1],
                1,
                min(count, max_lines),
                max_lines,
                payload=payload,
                requested_end=count,
            )
    if len(left) == 3 and Path(left[0]).name == "nl" and left[1] == "-ba":
        parsed = parse_sed_filter_range(right)
        if parsed is not None:
            start, end = parsed
            return plan_file_lines(
                pitlane_base,
                cwd,
                left[2],
                start,
                min(end, start + max_lines - 1),
                max_lines,
                payload=payload,
                requested_end=end,
            )
    return None


def split_single_unquoted_pipe(command: str) -> tuple[str, str] | None:
    quote = ""
    escaped = False
    pipe_index: int | None = None
    for index, char in enumerate(command):
        if escaped:
            escaped = False
            continue
        if char == "\\" and quote != "'":
            escaped = True
            continue
        if quote:
            if char == quote:
                quote = ""
            continue
        if char in {"'", '"'}:
            quote = char
            continue
        if char in {";", "<", ">", "`", "$", "&", "\n", "\r"}:
            return None
        if char == "|":
            if pipe_index is not None:
                return None
            pipe_index = index
    if quote or pipe_index is None:
        return None
    left = command[:pipe_index].strip()
    right = command[pipe_index + 1 :].strip()
    if not left or not right:
        return None
    return left, right


def parse_sed_filter_range(tokens: list[str]) -> tuple[int, int] | None:
    if len(tokens) != 3 or Path(tokens[0]).name != "sed" or tokens[1] != "-n":
        return None
    match = SED_RANGE_RE.match(tokens[2])
    if not match:
        return None
    start = int(match.group(1))
    end = int(match.group(2) or match.group(1))
    return (start, end) if end >= start else None


def parse_head(tokens: list[str]) -> tuple[int, str] | None:
    if len(tokens) == 1 and Path(tokens[0]).name == "head":
        return 10, "-"
    if len(tokens) == 3 and Path(tokens[0]).name == "head" and tokens[1] == "-n" and tokens[2].isdigit():
        return int(tokens[2]), "-"
    if len(tokens) == 2 and Path(tokens[0]).name == "head" and tokens[1].startswith("-n") and tokens[1][2:].isdigit():
        return int(tokens[1][2:]), "-"
    if len(tokens) == 2:
        return 10, tokens[1]
    if len(tokens) == 4 and tokens[1] == "-n" and tokens[2].isdigit():
        return int(tokens[2]), tokens[3]
    if len(tokens) == 3 and tokens[1].startswith("-n") and tokens[1][2:].isdigit():
        return int(tokens[1][2:]), tokens[2]
    return None


def parse_sed_range(tokens: list[str]) -> tuple[int, int, str] | None:
    if len(tokens) != 4 or tokens[1] != "-n":
        return None
    match = SED_RANGE_RE.match(tokens[2])
    if not match:
        return None
    start = int(match.group(1))
    end = int(match.group(2) or match.group(1))
    return start, end, tokens[3]


def parse_rg_symbol_search(tokens: list[str], cwd: Path | None = None) -> tuple[str, str | None] | None:
    if len(tokens) not in {2, 3}:
        return None
    if any(token.startswith("-") for token in tokens[1:]):
        return None
    if cwd is not None and path_is_excluded_from_navigation(cwd):
        return None
    query = tokens[1]
    if not is_strong_symbol_query(query):
        return None
    file_filter = None
    if len(tokens) == 3 and tokens[2] not in {".", "./"}:
        if "*" in tokens[2] or "?" in tokens[2] or "[" in tokens[2]:
            return None
        if path_arg_is_excluded_from_navigation(tokens[2]):
            return None
        file_filter = tokens[2].rstrip("/")
    return query, file_filter


def parse_grep_recursive_symbol_search(tokens: list[str], cwd: Path | None = None) -> tuple[str, str | None] | None:
    if len(tokens) not in {3, 4}:
        return None
    flags = tokens[1]
    if flags not in {"-R", "-r", "--recursive"}:
        return None
    if cwd is not None and path_is_excluded_from_navigation(cwd):
        return None
    query = tokens[2]
    if not is_strong_symbol_query(query):
        return None
    file_filter = None
    if len(tokens) == 4 and tokens[3] not in {".", "./"}:
        if path_arg_is_excluded_from_navigation(tokens[3]):
            return None
        file_filter = tokens[3].rstrip("/")
    return query, file_filter


def is_strong_symbol_query(query: str) -> bool:
    if not SYMBOL_RE.match(query):
        return False
    if "::" in query:
        return True
    if query.isupper() or query.islower():
        return False
    return bool(STRONG_SYMBOL_RE.match(query))


def parse_recursive_listing(tokens: list[str], cwd: Path | None = None) -> str | None:
    if cwd is not None and path_is_excluded_from_navigation(cwd):
        return None
    if tokens[0] == "tree":
        if len(tokens) == 1:
            return "."
        if len(tokens) == 2 and not tokens[1].startswith("-"):
            if path_arg_is_excluded_from_navigation(tokens[1]):
                return None
            return tokens[1]
        return None
    if tokens[0] != "ls":
        return None
    if len(tokens) == 2 and tokens[1] in {"-R", "-lR", "-laR", "-Ral", "-Rla"}:
        return "."
    if len(tokens) == 3 and tokens[1] in {"-R", "-lR", "-laR", "-Ral", "-Rla"}:
        if path_arg_is_excluded_from_navigation(tokens[2]):
            return None
        return tokens[2]
    return None


def parse_find_source_listing(tokens: list[str], cwd: Path | None = None) -> bool:
    if not tokens or Path(tokens[0]).name != "find":
        return False
    if cwd is not None and path_is_excluded_from_navigation(cwd):
        return False
    if any(path_arg_is_excluded_from_navigation(token) for token in tokens[1:] if not token.startswith("-")):
        return False
    if any(token in {"-delete", "-exec", "-execdir", "-ok", "-okdir"} for token in tokens):
        return False
    if any(tokens[index] == "-type" and index + 1 < len(tokens) and tokens[index + 1] == "f" for index in range(len(tokens))):
        return True
    for index, token in enumerate(tokens[:-1]):
        if token not in {"-name", "-iname", "-path", "-ipath"}:
            continue
        pattern = tokens[index + 1].lower()
        if any(pattern.endswith(f"*{extension}") or pattern.endswith(extension) for extension in SOURCE_EXTS):
            return True
    return False


def parse_git_grep_source_search(tokens: list[str], cwd: Path | None = None) -> bool:
    if len(tokens) < 3 or Path(tokens[0]).name != "git" or tokens[1] != "grep":
        return False
    if cwd is not None and path_is_excluded_from_navigation(cwd):
        return False
    if any(path_arg_is_excluded_from_navigation(token) for token in tokens[3:] if not token.startswith("-")):
        return False
    for token in tokens[2:]:
        if token == "--":
            break
        if token.startswith("-"):
            continue
        return True
    return False


def path_arg_is_excluded_from_navigation(path_arg: str) -> bool:
    if not path_arg or path_arg in {".", "./"}:
        return False
    expanded = path_arg.replace("\\", "/")
    parts = [part for part in Path(expanded).parts if part not in {"", os.sep}]
    if any(part in EXCLUDED_NAV_PATH_PARTS for part in parts):
        return True
    suffix = Path(expanded).suffix.lower()
    return suffix in EXCLUDED_NAV_SUFFIXES


def path_is_excluded_from_navigation(path: Path) -> bool:
    try:
        resolved = path.resolve()
    except OSError:
        resolved = path
    expanded = resolved.as_posix()
    absolute_parts = [part for part in resolved.parts if part not in {"", os.sep}]
    if any(part in ABSOLUTE_EXCLUDED_NAV_PATH_PARTS for part in absolute_parts):
        return True
    project = git_root(resolved if resolved.is_dir() else resolved.parent)
    try:
        scoped = resolved.relative_to(project)
    except ValueError:
        scoped = resolved
    parts = [part for part in scoped.parts if part not in {"", os.sep}]
    return any(part in EXCLUDED_NAV_PATH_PARTS for part in parts)


def resolve_source_file(cwd: Path, path_arg: str) -> Path | None:
    if path_arg_is_excluded_from_navigation(path_arg):
        return None
    path = resolve_existing_path(cwd, path_arg)
    if path is None or not path.is_file() or path.is_symlink():
        return None
    if path_is_excluded_from_navigation(path):
        return None
    if path.suffix.lower() in SOURCE_EXTS:
        return path
    if path.suffix or not os.access(path, os.X_OK) or not has_source_shebang(path):
        return None
    return path


def has_source_shebang(path: Path) -> bool:
    try:
        with path.open("rb") as handle:
            first_line = handle.readline(256)
    except OSError:
        return False
    return bool(SOURCE_SHEBANG_RE.match(first_line))


def estimate_line_savings(
    path: Path,
    start: int,
    visible_end: int,
    *,
    requested_end: int | None,
    total_lines: int,
) -> dict:
    if requested_end is None and start == 1:
        try:
            requested_bytes = path.stat().st_size
        except OSError:
            requested_bytes = estimate_range_bytes(path, start, total_lines)
    else:
        requested_bytes = estimate_range_bytes(path, start, requested_end or total_lines)
    visible_bytes = estimate_range_bytes(path, start, visible_end)
    saved_bytes = max(0, requested_bytes - visible_bytes)
    return {
        "estimated_input_bytes": requested_bytes,
        "estimated_output_bytes": visible_bytes,
        "estimated_saved_bytes": saved_bytes,
        "estimated_saved_tokens": max(0, round(saved_bytes / 4)),
    }


def estimate_range_bytes(path: Path, start: int, end: int) -> int:
    if end < start:
        return 0
    total = 0
    try:
        with path.open("rb") as handle:
            for line_no, line in enumerate(handle, 1):
                if line_no < start:
                    continue
                if line_no > end:
                    break
                total += len(line)
    except OSError:
        return 0
    return total


def resolve_existing_path(cwd: Path, path_arg: str) -> Path | None:
    if any(marker in path_arg for marker in ["*", "?", "["]):
        return None
    path = Path(path_arg)
    if not path.is_absolute():
        path = cwd / path
    try:
        return path.resolve(strict=True)
    except OSError:
        return None


def git_root(start: Path) -> Path:
    try:
        result = subprocess.run(
            ["git", "-C", str(start), "rev-parse", "--show-toplevel"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
            timeout=1.0,
        )
        if result.returncode == 0:
            root = Path(result.stdout.strip())
            if root.is_absolute() and root.exists():
                return root.resolve()
    except Exception:
        pass
    return start.resolve() if start.is_dir() else start.parent.resolve()


def relative_to_project(path: Path, project: Path) -> str:
    try:
        return path.relative_to(project).as_posix()
    except ValueError:
        return path.name


def count_text_lines(path: Path, max_lines: int) -> int | None:
    try:
        with path.open("rb") as handle:
            first = handle.read(8192)
            if b"\0" in first:
                return None
            lines = first.count(b"\n")
            saw_bytes = bool(first)
            last_byte = first[-1:] if first else b""
            while lines <= max_lines:
                chunk = handle.read(65536)
                if not chunk:
                    break
                if b"\0" in chunk:
                    return None
                saw_bytes = True
                last_byte = chunk[-1:]
                lines += chunk.count(b"\n")
    except OSError:
        return None
    if saw_bytes and last_byte != b"\n":
        lines += 1
    return max(1, lines)


def pitlane_index_ready(pitlane_base: list[str], project: Path) -> bool:
    if enabled(os.environ.get("PITLANE_CODEX_ASSUME_INDEXED")):
        return True
    try:
        result = subprocess.run(
            [*pitlane_base, "stats", str(project)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
            timeout=2.0,
        )
    except Exception:
        return False
    return result.returncode == 0


def ensure_pitlane_index_ready(
    pitlane_base: list[str],
    project: Path,
    *,
    payload: dict | None = None,
    required: bool = True,
) -> bool:
    if pitlane_index_ready(pitlane_base, project):
        return True
    if not enabled(os.environ.get("PITLANE_CODEX_AUTO_INDEX", "1")):
        return False
    if not is_safe_auto_index_project(project):
        record_telemetry(payload, "auto_index_skipped", project=project, reason="unsafe-project-root")
        return False
    timeout = int_env("PITLANE_CODEX_AUTO_INDEX_TIMEOUT_SECS", 6, 1, 60)
    try:
        result = subprocess.run(
            [*pitlane_base, "index", str(project)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
            timeout=float(timeout),
        )
    except Exception:
        record_telemetry(payload, "auto_index_failed", project=project, reason="exception")
        return not required and pitlane_index_ready(pitlane_base, project)
    ok = result.returncode == 0 and pitlane_index_ready(pitlane_base, project)
    record_telemetry(
        payload,
        "auto_index_ready" if ok else "auto_index_failed",
        project=project,
        reason=f"returncode={result.returncode}",
    )
    return ok or not required


def is_safe_auto_index_project(project: Path) -> bool:
    try:
        resolved = project.resolve()
    except OSError:
        return False
    if not is_under_trusted_auto_index_root(resolved):
        return False
    parts = resolved.parts
    blocked = {"node_modules", ".git", "target", "dist", "build", ".cache", "__pycache__"}
    if any(part in blocked for part in parts):
        return False
    try:
        result = subprocess.run(
            ["git", "-C", str(resolved), "ls-files"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
            timeout=2.0,
        )
    except Exception:
        return False
    if result.returncode != 0:
        return False
    max_files = int_env("PITLANE_CODEX_AUTO_INDEX_MAX_FILES", 20000, 100, 200000)
    return result.stdout.count("\n") <= max_files


def trusted_auto_index_roots() -> list[Path]:
    override = os.environ.get("PITLANE_CODEX_AUTO_INDEX_ROOTS")
    if override:
        roots = [Path(item).expanduser() for item in override.split(os.pathsep) if item.strip()]
    else:
        roots = [Path.home(), Path.cwd(), Path("/workspace")]
    resolved_roots: list[Path] = []
    for root in roots:
        try:
            resolved_roots.append(root.resolve())
        except OSError:
            continue
    return resolved_roots


def is_under_trusted_auto_index_root(path: Path) -> bool:
    for root in trusted_auto_index_roots():
        try:
            path.relative_to(root)
            return True
        except ValueError:
            continue
    return False


def looks_like_source_navigation(tokens: list[str], cwd: Path) -> bool:
    if not tokens:
        return False
    executable = Path(tokens[0]).name
    if executable in {"cat", "head", "sed"}:
        return any(resolve_source_file(cwd, token) is not None for token in tokens[1:] if not token.startswith("-"))
    if executable in {"ls", "tree"}:
        return parse_recursive_listing(tokens, cwd) is not None
    if executable == "rg":
        return parse_rg_symbol_search(tokens, cwd) is not None
    if executable == "grep":
        return parse_grep_recursive_symbol_search(tokens, cwd) is not None
    if executable == "find":
        return parse_find_source_listing(tokens, cwd)
    if executable == "git":
        return parse_git_grep_source_search(tokens, cwd)
    return any(resolve_source_file(cwd, token) is not None for token in tokens[1:] if not token.startswith("-"))


def classify_tokens(tokens: list[str], cwd: Path) -> str:
    if not tokens:
        return "empty"
    executable = Path(tokens[0]).name
    if executable in {"rg", "grep"}:
        if parse_rg_symbol_search(tokens, cwd) is not None or parse_grep_recursive_symbol_search(tokens, cwd) is not None:
            return "symbol-search"
        return "literal-search"
    if executable in {"cat", "head", "sed"}:
        if any(resolve_source_file(cwd, token) is not None for token in tokens[1:] if not token.startswith("-")):
            return "source-read"
        return "file-read"
    if executable in {"ls", "tree", "find"}:
        return "listing"
    if executable == "git":
        if parse_git_grep_source_search(tokens, cwd):
            return "git-grep"
        return "git"
    return "non-source"


def should_hint_tokens(tokens: list[str], cwd: Path) -> bool:
    if not tokens:
        return False
    executable = Path(tokens[0]).name
    if executable in {"cat", "head", "sed"}:
        return any(resolve_source_file(cwd, token) is not None for token in tokens[1:] if not token.startswith("-"))
    if executable == "rg":
        return parse_rg_symbol_search(tokens, cwd) is not None
    if executable == "grep":
        return parse_grep_recursive_symbol_search(tokens, cwd) is not None
    if executable == "find":
        return parse_find_source_listing(tokens, cwd)
    if executable == "git":
        return parse_git_grep_source_search(tokens, cwd)
    if executable in {"ls", "tree"}:
        return parse_recursive_listing(tokens, cwd) is not None
    return False


def record_decision(
    payload: dict | None,
    command: str,
    decision: str,
    command_class: str,
    reason: str,
    cwd: Path,
    metrics: dict | None = None,
) -> None:
    if not enabled(os.environ.get("PITLANE_CODEX_TELEMETRY_DECISIONS")):
        return
    record_telemetry(
        payload,
        "decision",
        project=git_root(cwd),
        command=command,
        reason=reason,
        decision=decision,
        command_class=command_class,
        metrics=metrics,
    )


def emit_missed_hint(command: str, command_field: str, reason: str) -> None:
    if not enabled(os.environ.get("PITLANE_CODEX_HINT_MISSES", "1")):
        return
    output = {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "additionalContext": (
                f"Pitlane missed source-navigation opportunity: {reason}. "
                "Prefer Pitlane symbol/search/lines/outline context or direct source-read commands."
            ),
        }
    }
    print(json.dumps(output, separators=(",", ":")))


def telemetry_path() -> Path | None:
    if not enabled(os.environ.get("PITLANE_CODEX_TELEMETRY", "0")):
        return None
    override = os.environ.get("PITLANE_CODEX_TELEMETRY_PATH")
    if override:
        return Path(override).expanduser()
    state_home = os.environ.get("XDG_STATE_HOME")
    if state_home:
        return Path(state_home).expanduser() / "pitlane-codex-plugin" / "telemetry.jsonl"
    return Path.home() / ".local" / "state" / "pitlane-codex-plugin" / "telemetry.jsonl"


def record_telemetry(
    payload: dict | None,
    event: str,
    *,
    project: Path | None = None,
    command: str = "",
    reason: str = "",
    decision: str | None = None,
    command_class: str | None = None,
    metrics: dict | None = None,
) -> None:
    path = telemetry_path()
    if path is None:
        return
    record = {
        "schema_version": 1,
        "created_at": _dt.datetime.now(_dt.UTC).isoformat(),
        "event": event,
        "decision": decision,
        "command_class": command_class,
        "reason": reason,
        "command_hash": command_hash(command),
        "command_preview": command[:240]
        if command and enabled(os.environ.get("PITLANE_CODEX_TELEMETRY_COMMAND_PREVIEW"))
        else None,
        "project": str(project) if project else None,
        "session_id": payload.get("session_id") if isinstance(payload, dict) else None,
        "turn_id": payload.get("turn_id") if isinstance(payload, dict) else None,
        "tool_use_id": payload.get("tool_use_id") if isinstance(payload, dict) else None,
    }
    if metrics:
        for key, value in metrics.items():
            if isinstance(value, int):
                record[key] = value
    try:
        path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
        try:
            path.parent.chmod(0o700)
        except OSError:
            pass
        with path.open("a", encoding="utf8") as handle:
            handle.write(json.dumps(record, separators=(",", ":")) + "\n")
        try:
            path.chmod(0o600)
        except OSError:
            pass
    except OSError:
        return


def record_missed_opportunity(
    payload: dict | None,
    command: str,
    reason: str,
    cwd: Path,
) -> None:
    record_telemetry(payload, "missed_opportunity", project=git_root(cwd), command=command, reason=reason)


def command_hash(command: str) -> str | None:
    if not command:
        return None
    return hashlib.sha256(command.encode("utf8", errors="replace")).hexdigest()


def int_env(name: str, default: int, minimum: int, maximum: int) -> int:
    try:
        value = int(os.environ.get(name, ""))
    except ValueError:
        value = default
    return min(max(value, minimum), maximum)


def shell_join(tokens: list[str]) -> str:
    return " ".join(shlex.quote(token) for token in tokens)


if __name__ == "__main__":
    raise SystemExit(main())
